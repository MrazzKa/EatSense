{
  "name": "eatsense-mobile",
  "version": "1.0.0",
  "description": "EatSense Mobile Client - React Native + Expo",
  "main": "index.js",
  "scripts": {
    "start": "dotenv -e .env -- expo start --tunnel --clear",
    "start:tunnel": "dotenv -e .env -- expo start --tunnel --clear",
    "start:lan": "dotenv -e .env -- expo start --lan --clear",
    "start:dev": "REACT_NATIVE_PACKAGER_HOSTNAME=192.168.3.6 dotenv -e .env -- expo start --lan --clear --reset-cache",
    "start:dev:auto": "dotenv -e .env -- expo start --lan --clear",
    "convert-logo": "./scripts/convert-logo.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "npx eas-cli@latest build -p android --profile production",
    "build:ios": "npx eas-cli@latest build -p ios --profile production",
    "test": "jest",
    "test:run": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "test:e2e": "detox test",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "pre-commit": "pnpm run lint && pnpm run type-check && pnpm run test",
    "setup": "pnpm install && pnpm run setup:api",
    "i18n:extract": "node scripts/i18n-extract.js",
    "i18n:verify": "node scripts/i18n-verify.js",
    "i18n:check": "node scripts/check-translations.js",
    "i18n:check-all": "node scripts/check-all-translations.js",
    "i18n:check-db": "cd apps/api && node ../../scripts/check-db-translations.js",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "eas:whoami": "npx eas-cli@latest whoami",
    "eas:login": "npx eas-cli@latest login",
    "eas:build:ios:dev": "npx eas-cli@latest build -p ios --profile development",
    "eas:build:ios": "npx eas-cli@latest build -p ios --profile production --non-interactive",
    "eas:build:ios:local": "npx eas-cli@latest build --platform ios --profile production --local",
    "eas:build:android": "npx eas-cli@latest build -p android --profile production --non-interactive",
    "eas:submit:ios": "npx eas-cli@latest submit -p ios --profile production --latest --non-interactive",
    "eas:submit:android": "npx eas-cli@latest submit -p android --profile production --latest --non-interactive",
    "eas:build:submit:ios": "pnpm run eas:build:ios && pnpm run eas:submit:ios",
    "eas:build:submit:android": "pnpm run eas:build:android && pnpm run eas:submit:android",
    "check:errors": "bash check-errors.sh",
    "postinstall": "node scripts/patch-iap.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-community/slider": "5.1.2",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "7.8.5",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.3.16",
    "@react-navigation/stack": "7.6.4",
    "axios": "^1.7.2",
    "expo": "~55.0.8",
    "expo-apple-authentication": "~55.0.9",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.10",
    "expo-auth-session": "~55.0.9",
    "expo-blur": "^55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-camera": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "^55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-media-library": "~55.0.10",
    "expo-notifications": "~55.0.13",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "^55.0.14",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "i18next": "^23.16.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^13.5.0",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-iap": "12.15.1",
    "react-native-markdown-display": "^7.0.0-alpha.2",
    "react-native-reanimated": "~4.2.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "rn-emoji-keyboard": "^1.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@eslint/js": "^9.18.0",
    "@jest/globals": "^30.2.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.18.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "glob": "^13.0.6",
    "globals": "^16.5.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.11",
    "prettier": "^3.2.5",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "packageManager": "pnpm@10.19.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "pnpm": {
    "overrides": {
      "react-server-dom-webpack": "^19.2.0"
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  }
}
