{
  "name": "eatsense",
  "version": "1.0.0",
  "private": true,
  "description": "EatSense monorepo",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "mobile": "pnpm --filter eatsense-mobile",
    "api": "pnpm --filter eatsense-api",
    "portal": "pnpm --filter expert-portal",
    "start": "pnpm --filter eatsense-mobile start",
    "start:tunnel": "pnpm --filter eatsense-mobile start:tunnel",
    "start:lan": "pnpm --filter eatsense-mobile start:lan",
    "start:dev": "pnpm --filter eatsense-mobile start:dev",
    "start:dev:auto": "pnpm --filter eatsense-mobile start:dev:auto",
    "android": "pnpm --filter eatsense-mobile android",
    "ios": "pnpm --filter eatsense-mobile ios",
    "web": "pnpm --filter eatsense-mobile web",
    "test": "pnpm --filter eatsense-mobile test",
    "test:run": "pnpm --filter eatsense-mobile test:run",
    "test:watch": "pnpm --filter eatsense-mobile test:watch",
    "test:e2e": "pnpm --filter eatsense-mobile test:e2e",
    "lint": "pnpm --filter eatsense-mobile lint",
    "lint:fix": "pnpm --filter eatsense-mobile lint:fix",
    "type-check": "pnpm --filter eatsense-mobile type-check",
    "pre-commit": "pnpm run lint && pnpm run type-check && pnpm run test",
    "setup": "pnpm install && pnpm --filter eatsense-api setup:env",
    "convert-logo": "pnpm --filter eatsense-mobile convert-logo",
    "i18n:extract": "node scripts/i18n-extract.js",
    "i18n:verify": "node scripts/i18n-verify.js",
    "i18n:check": "node scripts/check-translations.js",
    "i18n:check-all": "node scripts/check-all-translations.js",
    "i18n:check-db": "cd apps/api && node ../../scripts/check-db-translations.js",
    "build": "pnpm --filter eatsense-api build",
    "start:prod": "pnpm --filter eatsense-api start:prod",
    "prisma:generate": "pnpm --filter eatsense-api prisma:generate",
    "prisma:migrate:deploy": "pnpm --filter eatsense-api prisma:migrate:deploy",
    "eas:whoami": "pnpm --filter eatsense-mobile eas:whoami",
    "eas:login": "pnpm --filter eatsense-mobile eas:login",
    "eas:build:ios:dev": "pnpm --filter eatsense-mobile eas:build:ios:dev",
    "eas:build:ios": "pnpm --filter eatsense-mobile eas:build:ios",
    "eas:build:ios:local": "pnpm --filter eatsense-mobile eas:build:ios:local",
    "eas:build:android": "pnpm --filter eatsense-mobile eas:build:android",
    "eas:submit:ios": "pnpm --filter eatsense-mobile eas:submit:ios",
    "eas:submit:android": "pnpm --filter eatsense-mobile eas:submit:android",
    "eas:build:submit:ios": "pnpm run eas:build:ios && pnpm run eas:submit:ios",
    "eas:build:submit:android": "pnpm run eas:build:android && pnpm run eas:submit:android"
  },
  "workspaces": [
    "apps/*"
  ],
  "pnpm": {
    "overrides": {
      "baseline-browser-mapping": "^2.10.32",
      "react-server-dom-webpack": "19.2.0"
    }
  }
}
