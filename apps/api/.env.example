# EatSense API Environment Variables
# Copy this file to .env and fill in the values

# URLs
API_BASE_URL=https://your-api-url.example.com
APP_BASE_URL=https://your-app-url.example.com
MAGIC_LINK_URL=https://eatsense.app/v1/auth/magic/consume

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/eatsense

# Redis
REDIS_URL=redis://localhost:6379
REDIS_BLACKLIST_PREFIX=auth:refresh:blacklist:

# Rate limits
ADMIN_BYPASS_LIMITS=false
DISABLE_LIMITS=false
FREE_DAILY_ANALYSES=3
PRO_DAILY_ANALYSES=25

# JWT Authentication (RS256)
JWT_ALG=RS256
JWT_KEY_ID=main-k1
JWT_PRIVATE_KEY_BASE64="<base64-encoded-rsa-private-key>"
JWT_PUBLIC_KEY="<pem-encoded-rsa-public-key>"
JWT_SECRET=<random-secret-string>
ACCESS_TOKEN_EXPIRES=45m
REFRESH_TOKEN_EXPIRES=30d

# OTP
OTP_EXPIRATION_MINUTES=10
OTP_RATE_LIMIT=5

# OpenAI
OPENAI_API_KEY=sk-proj-xxx

# FDC (USDA Food Data Central)
FDC_API_KEY=<your-fdc-api-key>

# Mail
MAIL_PROVIDER=SMTP
MAIL_DISABLE=false
AUTH_DEV_IGNORE_MAIL_ERRORS=false
MAIL_FROM="EatSense <your-email@example.com>"
SMTP_HOST=mail.example.com
SMTP_PASS=<smtp-password>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SENDGRID_API_KEY=SG.xxx

# S3 / MinIO
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=eatsense-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Timeouts
FDC_TIMEOUT_MS=5000
NUTRITION_PROVIDER_TIMEOUT_MS=5000
VISION_API_TIMEOUT_MS=90000
GRILLED_OIL_GRAMS=5
USE_GPT_FAST_PATH=true

# Apple / Google Auth
APPLE_BUNDLE_ID=ch.eatsense.app
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_IOS_CLIENT_ID=<google-ios-client-id>
GOOGLE_ANDROID_CLIENT_ID=<google-android-client-id>
GOOGLE_WEB_CLIENT_ID=<google-web-client-id>

# Cache TTLs (seconds)
CACHE_DEFAULT_TTL_SEC=900
USDA_CACHE_TTL_SEC=259200
ANALYSIS_CACHE_TTL_SEC=86400
ARTICLES_FEED_CACHE_TTL_SEC=900
ARTICLES_DETAIL_CACHE_TTL_SEC=86400
ASSISTANT_SESSION_TTL_SEC=1800
